{
  "name": "File Store Bot",
  "description": "Telegram File Store Bot with Custom Messages and Database Support.",
  "keywords": [
    "telegram",
    "bot",
    "pyrogram",
    "mongodb"
  ],
  "repository": "https://github.com/redopxxxx-create/File-StoreBot",
  "env": {
    "API_ID": {
      "description": "Get this from my.telegram.org",
      "required": true
    },
    "API_HASH": {
      "description": "Get this from my.telegram.org",
      "required": true
    },
    "BOT_TOKEN": {
      "description": "Get this from @BotFather",
      "required": true
    },
    "OWNER_ID": {
      "description": "Your Telegram User ID",
      "required": true
    },
    "DB_URI": {
      "description": "Your MongoDB URI (mongodb+srv://...)",
      "required": true
    },
    "DB_NAME": {
      "description": "Your MongoDB Database Name",
      "value": "Rex_sequencebott",
      "required": true
    },
    "DATABASE_CHANNEL": {
      "description": "The ID of the channel where files are stored (e.g., -100xxxx)",
      "required": true
    },
    "FSUB_PIC": {
      "description": "URL of Force Sub image",
      "value": "https://graph.org/file/...",
      "required": false
    },
    "START_PIC": {
      "description": "URL of Start image",
      "value": "https://graph.org/file/...",
      "required": false
    },
    "START_MSG": {
      "description": "Welcome message for users",
      "value": "Welcome to the bot!",
      "required": false
    },
    "ABOUT_MESSAGE": {
      "description": "Text for About section",
      "value": "About this bot...",
      "required": false
    },
    "HELP_MESSAGE": {
      "description": "Text for Help section",
      "value": "Here's how to use the bot...",
      "required": false
    }
  },
  "formation": {
    "worker": {
      "quantity": 1,
      "size": "eco"
    }
  },
  "buildpacks": [
    {
      "url": "heroku/python"
    }
  ]
}
